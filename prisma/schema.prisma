generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Contact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  name      String
  email     String
  intent    String
  message   String
}

model JoinApplication {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  email          String
  specialization String
}
